# ─── Database ────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/cafepos"

# ─── JWT Secrets ─────────────────────────────────────
JWT_ACCESS_SECRET="your-access-secret-change-me"
JWT_REFRESH_SECRET="your-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────
PORT=4000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# ─── SMTP (optional, falls back to console log) ─────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Café POS <noreply@cafepos.local>"

# ─── Admin Seeds ─────────────────────────────────────
ADMIN_EMAILS="admin@cafepos.local"
ADMIN_DEFAULT_PASSWORD="Admin@123"

# ─── Razorpay (optional, mock mode if empty) ────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ─── Uploads ─────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
